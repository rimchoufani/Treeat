# Copy to .env for local overrides. On Vercel, set this as an Environment Variable.
# PUBLIC value (baked into the browser bundle) — never put a secret here.
# Leave empty in dev: vite.config.js proxies /api → localhost:8000.
# In prod set to your Railway backend URL, e.g. https://treeat-backend.up.railway.app
VITE_API_URL=
